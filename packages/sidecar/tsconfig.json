{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "types": ["node", "bun-types"],
    "paths": {
      "@sb/core/*": ["../core/src/*"],
      "@sb/sidecar/*": ["./src/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["./**/*"]
}
